
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// datasource db {
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
// }

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Url {
  id        String @id @default(cuid())
  longUrl   String
  shortCode String @unique
  createdAt DateTime @default(now())
}
